package {{service.namespace}}.configuration

import org.springframework.boot.context.properties.ConfigurationProperties
import org.springframework.boot.jdbc.DataSourceBuilder
import org.springframework.context.annotation.Bean
import org.springframework.context.annotation.Configuration
import javax.sql.DataSource

/**
 * Datasource configurations.
 */
@Configuration
class DatasourceConfig {
    {{#each service.datasources as |datasource| ~}}
    @Bean
    @ConfigurationProperties(prefix="datasource.{{hyphen datasource.name}}")
    fun {{lower-camel datasource.name}}Datasource(): DataSource = DataSourceBuilder.create().build()
    {{/each}}
}